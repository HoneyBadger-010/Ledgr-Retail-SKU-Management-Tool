# Sunrise Demand AI — Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://sunrise:sunrise_secure@localhost:5432/sunrise_db

# Flask
FLASK_SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=production

# AI / Chatbot
OPENROUTER_KEY=your-openrouter-api-key
GEMINI_API_KEY=your-gemini-api-key

# WhatsApp (Twilio) — Brief Part 2I
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
OWNER_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Email (Flask-Mail) — Brief Part 2I
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
OWNER_EMAIL=owner@sunrise.com

# Telegram (optional) — Brief Part 2I
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
